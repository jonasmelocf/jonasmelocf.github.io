		"@vue/tsconfig": "^0.9.1",
		"gh-pages": "^6.3.0",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3",
		"vitepress": "^2.0.0-alpha.17"
	},
	"dependencies": {
		"@lucide/vue": "^1.8.0",
		"@tailwindcss/vite": "^4.2.4",
		"@types/howler": "^2.2.12",
		"clsx": "^2.1.1",
		"howler": "^2.2.4",
		"monaco-editor": "^0.55.1",
		"pretty-format": "^30.3.0",
		"tailwind-merge": "^3.5.0",
